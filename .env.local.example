# Copy this file to `.env.local` (same folder) and fill in the real values.
# `.env.local` is git-ignored by Next.js, so your token will not be committed.

# Your store's myshopify.com domain (no https://, no trailing slash).
SHOPIFY_STORE_DOMAIN=magic-coils-professional-hair-products.myshopify.com

# Storefront API access token from the custom app you installed in Shopify admin.
# Admin: Apps -> Develop apps -> <your app> -> API credentials -> Storefront API access token.
SHOPIFY_STOREFRONT_TOKEN=paste-your-storefront-api-token-here

# Optional: pin a specific Storefront API version (defaults to 2025-01 in code).
# SHOPIFY_API_VERSION=2025-01
